# AssemblyAI - Transcripción y diarización
ASSEMBLYAI_API_KEY=
# Motor de ASR: "assemblyai", "openai" (Whisper) o "mock" (sin API key, para desarrollo)
ASR_PROVIDER=assemblyai
# Modelo de OpenAI para transcripción cuando ASR_PROVIDER=openai
ASR_OPENAI_MODEL=whisper-1
# Texto de ejemplo usado cuando ASR_PROVIDER=mock
ASR_MOCK_TRANSCRIPT_TEXT=
# Opcional: polling más frecuente = menos demora al terminar la transcripción (ms, mín. 200). Por defecto 800.
# ASSEMBLYAI_POLLING_INTERVAL_MS=800
# Opcional: "false" desactiva diarización (medico/paciente); suele acortar el tiempo de AssemblyAI.
# ASSEMBLYAI_SPEAKER_LABELS=true

# OpenAI - Generación clínica (SOAP, recetas, etc.)
OPENAI_API_KEY=
# Opcional: modelo para análisis de estudios complementarios (visión + texto). Por defecto gpt-4o-mini.
# COMPLEMENTARY_STUDIES_OPENAI_MODEL=gpt-4o-mini
# El orquestador clínico usa estrategia determinística con reglas explícitas.
# Timeouts y retries por agente (ms/int)
AGENT_SOAP_TIMEOUT_MS=40000
AGENT_SOAP_RETRIES=1
AGENT_MEDICATION_TIMEOUT_MS=25000
AGENT_MEDICATION_RETRIES=1
AGENT_STUDIES_TIMEOUT_MS=25000
AGENT_STUDIES_RETRIES=1
AGENT_DOCUMENTS_TIMEOUT_MS=25000
AGENT_DOCUMENTS_RETRIES=1
AGENT_FOLLOWUPS_TIMEOUT_MS=20000
AGENT_FOLLOWUPS_RETRIES=1
# Adjuntos: análisis de estudios complementarios (MedGemma / OpenAI) — uso desde API de cargas
AGENT_COMPLEMENTARY_STUDIES_TIMEOUT_MS=60000
AGENT_COMPLEMENTARY_STUDIES_RETRIES=1

# QBI2 - Receta electrónica (preparado, no activo por defecto)
# Mantener en false hasta cierre comercial/técnico con QBI2.
QBI2_ISSUE_ENABLED=false
QBI2_BASE_URL=
QBI2_BEARER_TOKEN=
QBI2_CLIENTE_APP_ID=0
QBI2_LUGAR_ATENCION=
QBI2_TIMEOUT_MS=12000

# NextAuth - Autenticación (generar con: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL="http://localhost:3000"

# Base de datos
# Ejemplo: postgresql://user:password@localhost:5432/escriba_medico
# Para Prisma Postgres local: npx prisma dev
DATABASE_URL="postgresql://user:password@localhost:5432/escriba_medico"
