# AssemblyAI - Transcripción y diarización
ASSEMBLYAI_API_KEY=

# OpenAI - Generación clínica (SOAP, recetas, etc.)
OPENAI_API_KEY=

# NextAuth - Autenticación (generar con: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL="http://localhost:3000"

# Base de datos
# Ejemplo: postgresql://user:password@localhost:5432/escriba_medico
# Para Prisma Postgres local: npx prisma dev
DATABASE_URL="postgresql://user:password@localhost:5432/escriba_medico"
